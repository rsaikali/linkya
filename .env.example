# ============================================
# Configuration globale NILMIA - Exemple
# ============================================
# Copiez ce fichier en .env et adaptez les valeurs

# Base de données distante MySQL (lecture seule)
REMOTE_DB_HOST=192.168.1.200
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=linky
REMOTE_DB_USER=linky
REMOTE_DB_PASSWORD=your_password_here
REMOTE_DB_TABLE=linky_realtime

# Base de données locale TimescaleDB
LOCAL_DB_HOST=timescaledb
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=local_data
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Configuration de synchronisation
SYNC_INTERVAL_SECONDS=5
SYNC_RETENTION_HOURS=48

# Configuration NILM-CNN (supervisé)
CNN_TRAINING_INTERVAL_HOURS=24
CNN_DETECTION_INTERVAL_MINUTES=5
CNN_DETECTION_PERIOD_HOURS=24   # Période analysée lors de chaque détection

# Taille de la fenêtre d'analyse (en minutes)
# Valeurs recommandées : 10-120 min
# - Court (10-30min) : détecte événements brefs, moins de contexte
# - Moyen (30-60min) : bon compromis général
# - Long (60-120min) : capture cycles complets, meilleure précision
CNN_WINDOW_SIZE_MINUTES=60

CNN_MIN_POWER_THRESHOLD=30
CNN_MIN_DURATION_SECONDS=30

# Paramètres du modèle CNN
CNN_MODEL_PATH=/app/models/cnn
CNN_BATCH_SIZE=32
CNN_EPOCHS=50
CNN_LEARNING_RATE=0.001
CNN_VALIDATION_SPLIT=0.2

# Augmentation de données CNN
CNN_AUGMENTATION_ENABLED=true
CNN_NOISE_FACTOR=0.02
CNN_SHIFT_RANGE=30

# Feature engineering CNN
CNN_FFT_ENABLED=true
CNN_GRADIENT_ENABLED=true
CNN_STATISTICS_ENABLED=true
