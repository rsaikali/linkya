# ============================================
# LINKYA Configuration - Example File
# ============================================
# Copy this file to .env and adjust the values according to your environment

# ============================================
# HOME ASSISTANT
# ============================================

# HA base URL and long-lived access token
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_token_here

# Linky power entity in HA (SINSTS, VA)
HA_ENTITY_PAPP=sensor.linky_sinsts

# Days of history to backfill at startup (0 = skip backfill)
HA_BACKFILL_DAYS=30
HA_PUBLISH_POLL_INTERVAL=30

# HA Mosquitto broker (used for statestream real-time + ha-publish discovery)
HA_MQTT_HOST=homeassistant.local
HA_MQTT_PORT=1883
HA_MQTT_USER=homeassistant
HA_MQTT_PASSWORD=your_mqtt_password_here

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Local TimescaleDB database (read/write)
LOCAL_DB_HOST=timescaledb
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=linkya_db
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# ============================================
# CELERY & REDIS CONFIGURATION
# ============================================

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# NILM SERVICE CONFIGURATION
# ============================================

# --- Schedule ---

# Detection interval (in minutes) — cron job, analyzes last 2h rolling window
NILM_DETECTION_INTERVAL_MINUTES=5

# Detection analysis period (in hours)
# Time window to analyze during each detection run (null = all available data)
NILM_DETECTION_PERIOD_HOURS=240

# --- Analysis Window Configuration ---

# Analysis window size (in minutes)
# Recommended values for Sequence-to-Point: 5-30 min
# - Short (5-10 min): fast processing, simple events, less context
# - Medium (10-20 min): good balance (RECOMMENDED)
# - Long (20-30 min): captures complex cycles, more context
NILM_WINDOW_SIZE_MINUTES=10
# Sequence length in samples — set to match data density (HA Linky ~1pt/8s → 50pts ≈ 7min)
NILM_SEQUENCE_LENGTH=50

# --- Detection Thresholds ---

# Minimum power threshold (in Watts)
# Events below this power level are ignored
NILM_MIN_POWER_THRESHOLD=200

# Minimum event duration (in seconds)
# Events shorter than this are filtered out
NILM_MIN_DURATION_SECONDS=60

# --- Model Training Parameters ---

# Directory path for storing trained models
NILM_MODEL_PATH=/app/models

# Training batch size
# Larger values = faster but more memory usage
NILM_BATCH_SIZE=32

# Maximum training epochs
# Early stopping may stop training before reaching this value
NILM_EPOCHS=50

# Learning rate for model optimization
NILM_LEARNING_RATE=0.001

# Validation split ratio
# Fraction of data used for validation during training
NILM_VALIDATION_SPLIT=0.2

# --- Model Architecture ---

# GPU/CPU configuration
# Values: "true" (force GPU), "false" (force CPU), "auto" (auto-detect)
USE_GPU=auto

# NILM model architecture type
# Values: "lstm", "gru"
# Recommended: "gru" (faster than LSTM, good performance)
NILM_MODEL_TYPE=gru

# Enable state/cycle detection per appliance
# Detects specific states like heating, washing, spinning, etc.
NILM_DETECT_STATES=true

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API URL for backend connection (empty = use relative path via nginx proxy)
REACT_APP_API_URL=

# WebSocket URL for real-time updates (empty = use relative path via nginx proxy)
REACT_APP_WS_URL=
