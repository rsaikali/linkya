# ============================================
# Configuration globale NILMIA - Exemple
# ============================================
# Copiez ce fichier en .env et adaptez les valeurs

# Base de données distante MySQL (lecture seule)
REMOTE_DB_HOST=192.168.1.200
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=linky
REMOTE_DB_USER=linky
REMOTE_DB_PASSWORD=your_password_here
REMOTE_DB_TABLE=linky_realtime

# Base de données locale TimescaleDB
LOCAL_DB_HOST=timescaledb
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=linkya_db
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Configuration de synchronisation
SYNC_INTERVAL_SECONDS=5
SYNC_RETENTION_HOURS=48

# Configuration NILM (Sequence-to-Point pour désagrégation)
NILM_TRAINING_INTERVAL_HOURS=24
NILM_DETECTION_INTERVAL_MINUTES=5
NILM_DETECTION_PERIOD_HOURS=240   # Période analysée lors de chaque détection

# Taille de la fenêtre d'analyse (en minutes)
# Valeurs recommandées pour S2P : 5-30 min
# - Court (5-10min) : rapide, événements simples, moins de contexte
# - Moyen (10-20min) : bon compromis (RECOMMANDÉ)
# - Long (20-30min) : capture cycles complexes, plus de contexte
NILM_WINDOW_SIZE_MINUTES=10

NILM_MIN_POWER_THRESHOLD=30       # Seuil minimal de puissance (W)
NILM_MIN_DURATION_SECONDS=30      # Durée minimale d'un événement (s)

# Paramètres du modèle NILM
NILM_MODEL_PATH=/app/models
NILM_BATCH_SIZE=32
NILM_EPOCHS=50                    # Max epochs (early stopping peut arrêter avant)
NILM_LEARNING_RATE=0.001
NILM_VALIDATION_SPLIT=0.2

# ============================================
# NOUVELLES VARIABLES NILM S2P
# ============================================

# Device configuration (CPU/GPU)
# Valeurs : "true" (forcer GPU), "false" (forcer CPU), "auto" (détection auto)
USE_GPU=auto

# Type de modèle NILM (architecture RNN)
# Valeurs : "lstm", "gru", "attention"
# Recommandé : "gru" (plus rapide que LSTM, performant)
NILM_MODEL_TYPE=gru

# Activer la détection d'états/cycles par appareil
# (chauffage, lavage, essorage, etc.)
NILM_DETECT_STATES=true
