# ============================================
# LINKYA Configuration — copy to .env and adjust
# ============================================

# ── Home Assistant ──────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_token_here
HA_ENTITY_PAPP=sensor.linky_sinsts        # Linky power sensor (SINSTS, VA)
HA_BACKFILL_DAYS=30                        # days of history to import (0 = skip)

# HA Mosquitto broker (statestream in + discovery out)
HA_MQTT_HOST=homeassistant.local
HA_MQTT_PORT=1883
HA_MQTT_USER=homeassistant
HA_MQTT_PASSWORD=your_mqtt_password_here
HA_PUBLISH_POLL_INTERVAL=30

# ── Database (PostgreSQL) ───────────────────
LOCAL_DB_HOST=postgres
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=linkya_db
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# ── Internal service URLs (Docker network) ──
NILM_URL=http://nilm:8001
BACKEND_URL=http://backend:8000

# Host IP the backend binds to in prod (LAN, never 0.0.0.0)
BACKEND_BIND=192.168.1.111

# ── NILM ────────────────────────────────────
NILM_DETECTION_INTERVAL_MINUTES=5          # detect cron, rolling 2h window
NILM_DETECTION_PERIOD_HOURS=240
NILM_WINDOW_SIZE_MINUTES=10
NILM_SEQUENCE_LENGTH=50                     # samples (~7min at HA 1pt/8s)
NILM_MIN_POWER_THRESHOLD=200
NILM_MIN_DURATION_SECONDS=60
NILM_MODEL_PATH=/app/models
NILM_BATCH_SIZE=32
NILM_EPOCHS=50
NILM_LEARNING_RATE=0.001
NILM_VALIDATION_SPLIT=0.2
USE_GPU=auto                               # true | false | auto
NILM_MODEL_TYPE=gru                        # lstm | gru
NILM_DETECT_STATES=true
