# ============================================
# Mosquitto MQTT Broker - Environment Configuration
# ============================================
# Configuration file for standalone Mosquitto deployment
# Copy this file to .env and adjust values for your environment

# ============================================
# SYSTEM CONFIGURATION
# ============================================

# Timezone for service
TZ=Europe/Paris

# ============================================
# MQTT BROKER CONFIGURATION
# ============================================

# TLS/SSL Configuration
MQTT_TLS_ENABLED=true
MQTT_SERVER_NAME=raspberrypi.local
MQTT_MUTUAL_TLS=false

# ============================================
# AUTHENTICATION CREDENTIALS
# ============================================

# Admin user (full access to all topics)
MQTT_ADMIN_PASSWORD=change_me_admin_password

# Backend service (Linkya backend connection)
MQTT_BACKEND_PASSWORD=change_me_backend_password

# Monitor service (read-only monitoring)
MQTT_MONITOR_PASSWORD=change_me_monitor_password

# Guest user (limited read access)
MQTT_GUEST_PASSWORD=change_me_guest_password

# ============================================
# PRM-BASED CLIENT AUTHENTICATION
# ============================================

# Format: PRM1:password1,PRM2:password2,...
# Example: 09714037613599:pAssw0rd,12345678901234:meter2_pass
# Each Linky meter authenticates with its PRM as username
MQTT_PRM_PASSWORDS=09714037613599:pAssw0rd

# ============================================
# NETWORK CONFIGURATION
# ============================================

# Mosquitto will listen on all interfaces (0.0.0.0)
# Ensure firewall rules allow connections on ports:
# - 1883 (MQTT non-encrypted)
# - 8883 (MQTT over TLS)
# - 9001 (WebSocket non-encrypted)
# - 9002 (WebSocket over TLS)
