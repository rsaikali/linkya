# Mosquitto service specific ignores

# Environment variables
.env

# TLS certificates and private keys
certs/*.crt
certs/*.key
certs/*.csr
certs/*.srl
certs/*.ext
certs/*.pem

# Password files
config/passwd
config/*.passwd

# Temporary files
*.tmp
*.bak

# Logs
logs/
*.log

# Docker volumes
data/
certs/
logs/

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Python cache
__pycache__/
*.pyc
*.pyo