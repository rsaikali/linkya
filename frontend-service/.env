# Variables d'environnement du frontend

# API URL - Leave empty to use relative URLs through Nginx proxy
# Only set this if you need to connect to a different backend (e.g., development)
# REACT_APP_API_URL=http://localhost:8000

# WebSocket URL - Leave empty to use relative URLs through Nginx proxy
# Only set this if you need to connect to a different backend
# REACT_APP_WS_URL=ws://localhost:8000
