{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Backend Service (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend-service",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend-service/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Sync Worker (Celery)",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "src.tasks",
        "worker",
        "--loglevel=info"
      ],
      "cwd": "${workspaceFolder}/sync-service",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/sync-service/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: NILM Worker (Celery)",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "src.tasks",
        "worker",
        "--loglevel=info"
      ],
      "cwd": "${workspaceFolder}/nilm-service",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/nilm-service/src"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Pytest (Current File)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
